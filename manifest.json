{
  "manifest_version": 3,
  "name": "Quick Filter for TikTok Seller",
  "version": "1.0.0",
  "description": "Floating widget เพื่อ scan ออเดอร์และกรองสินค้าด้วยคลิกเดียวในแท็บที่จะจัดส่ง",
  "permissions": [],
  "host_permissions": [
    "https://seller-th.tiktok.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://seller-th.tiktok.com/order*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
