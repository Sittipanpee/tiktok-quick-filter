{
  "manifest_version": 3,
  "name": "Quick Filter for TikTok Seller",
  "version": "1.3.0",
  "description": "Floating widget เพื่อ scan ออเดอร์และกรองสินค้าด้วยคลิกเดียวในแท็บที่จะจัดส่ง",
  "permissions": [],
  "host_permissions": [
    "https://seller-th.tiktok.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://seller-th.tiktok.com/order*", "https://seller-th.tiktok.com/shipment/labels*"],
      "js": ["vendor/pdf-lib.min.js", "vendor/fontkit.umd.min.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://seller-th.tiktok.com/shipment/labels*"],
      "js": ["asset-bridge.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["vendor/Sarabun-Bold.ttf"],
      "matches": ["https://seller-th.tiktok.com/*"]
    }
  ]
}
